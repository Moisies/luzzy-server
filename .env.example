# ─── Base de datos ────────────────────────────────────────────────────────────
# PostgreSQL vía Docker Compose (ver docker-compose.yml)
DATABASE_URL="postgresql://luzzy:luzzypass123@localhost:5432/luzzy"

# ─── Autenticación JWT ────────────────────────────────────────────────────────
# Cambia esto por un valor aleatorio seguro en producción
JWT_SECRET="cambia-este-valor-en-produccion"

# ─── Google Gemini API ────────────────────────────────────────────────────────
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# Modelo a usar (gemini-1.5-flash es el más rápido y económico)
GEMINI_MODEL="gemini-2.0-flash"

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Descarga las credenciales desde Firebase Console → Configuración → Cuentas de servicio
FIREBASE_PROJECT_ID="tu-proyecto-firebase"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com"
# IMPORTANTE: las \n deben estar como literales \n (sin saltos de línea reales)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000

# ─── Docker Compose (opcional) ───────────────────────────────────────────────
POSTGRES_PASSWORD=luzzypass123
